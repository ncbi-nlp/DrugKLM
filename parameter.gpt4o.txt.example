# Copy this file to parameter.gpt4o.txt, then fill in your credentials.
# Format is TAB-separated KEY<TAB>VALUE (one entry per line).
# Lines starting with '#' are comments; blank lines are ignored.
#
# === OpenAI public API (default for the macos-openai-patches port) ===
OPENAI_API_KEY	sk-PUT_YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL	gpt-4o
OPENAI_BASE_URL	https://api.openai.com/v1
#
# === Azure OpenAI (alternative) ===
# To use Azure instead of public OpenAI, comment out the OPENAI_* lines
# above and uncomment the four lines below, populating values from your
# Azure AI Studio deployment.
# AZURE_OPENAI_ENDPOINT	https://your-resource.openai.azure.com/
# API_KEY	YOUR_AZURE_KEY_HERE
# DEPLOYMENT_NAME	gpt-4o
# API_VERSION	2024-05-01-preview
